# ─────────────────────────────────────────────────────────────────
# AI Software Compiler — Environment Variables
# Copy this file to .env and fill in your values.
# Local setup: only GEMINI_API_KEY is required to run the pipeline.
# ─────────────────────────────────────────────────────────────────

# ── REQUIRED ────────────────────────────────────────────────────

# Google Gemini API key (primary provider for schema/appspec stages)
GEMINI_API_KEY=your_gemini_api_key_here

# ── OPTIONAL: Additional AI Providers ───────────────────────────
# At least one is required for multi-provider routing to work fully.
# Groq is used as primary for intent extraction (ultra-fast).

# Groq (recommended: fast, cheap — used for intent extraction)
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (GPT-4o, GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude 3.5 Haiku, Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenRouter (universal fallback — handles 429/5xx from primary providers)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── DATABASE ────────────────────────────────────────────────────
# Leave empty to use SQLite (default for local dev)
# Set to PostgreSQL URL for production
DATABASE_URL=sqlite:///./app_studio.db

# ── CORS ────────────────────────────────────────────────────────
# Frontend URL for CORS allow_origins
FRONTEND_URL=http://localhost:3000

# ── PIPELINE CONFIG ─────────────────────────────────────────────
# Max repair retries per stage (default: 3)
MAX_REPAIR_RETRIES=3
